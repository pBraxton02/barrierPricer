# Load libraries
library(ggplot2)
library(dplyr)
library(viridis)
library(scales)
library(ggridges)




borough_stats_plot <- airbnb %>%
  filter(price > 0 & price < 500) %>%
  ggplot(aes(x = reorder(neighbourhood_group, price, FUN = median), y = price, fill = neighbourhood_group)) +
  geom_boxplot(outlier.alpha = 0.1, outlier.size = 0.5, color = "#2C3E50") +
  coord_flip() + # Makes it much more legible
  scale_y_continuous(labels = label_dollar()) +
  scale_fill_viridis_d(option = "plasma") +
  labs(
    title = "Price Variance Across NYC Boroughs",
    x = NULL,
    y = "Price per Night"
  ) +
  theme_light() +
  theme(legend.position = "none")



price_dist_plot <- airbnb %>%
  filter(price > 0 & price < 600) %>% # Filtering for the 'bulk' to avoid extreme outliers
  ggplot(aes(x = price, y = reorder(neighbourhood_group, price, FUN = median), fill = stat(x))) +
  geom_density_ridges_gradient(scale = 3, rel_min_height = 0.01, color = "white") +
  scale_fill_viridis_c(option = "mako", name = "Price") +
  scale_x_continuous(labels = label_dollar()) +
  labs(
    title = "Price Distribution Density by Borough",
    x = "Price per Night",
    y = NULL
  ) +
  theme_minimal(base_size = 12) +
  theme(legend.position = "none", panel.grid.minor = element_blank())


# Legible Price Comparison across Boroughs
price_distr <- airbnb %>%
  filter(price > 0, price < 400) %>%
  ggplot(aes(x = price, fill = neighbourhood_group)) +
  geom_histogram(binwidth = 20, color = "white", alpha = 0.8) +
  facet_wrap(~ neighbourhood_group, scales = "free_y") +
  scale_x_continuous(labels = label_dollar()) +
  scale_fill_viridis_d(option = "plasma") +
  labs(
    title = "Price Frequency Distribution by Borough",
    x = "Price per Night",
    y = "Number of Listings"
  ) +
  theme_minimal() +
  theme(
    legend.position = "none",
    strip.text = element_text(face = "bold")
  )

# Phase 2: Host Category Comparison
# Defining Host Type: Individual (1 listing) vs. Professional (2+ listings)
host_comparison_data <- airbnb %>%
  filter(price > 0 & price < 500) %>%
  mutate(host_type = ifelse(calculated_host_listings_count > 1, "Professional", "Individual"))

# Plot: Comparing price distributions by Host Type across Boroughs
ggplot(host_comparison_data, aes(x = host_type, y = price, fill = host_type)) +
  geom_boxplot(outlier.alpha = 0.05, outlier.size = 0.5, color = "#34495E") +
  facet_wrap(~neighbourhood_group, nrow = 1) +
  scale_y_continuous(labels = label_dollar()) +
  scale_fill_manual(values = c("#AAB7B8", "#F39C12")) + # Muted grey for individuals, bold orange for pros
  labs(
    title = "Pricing Comparison: Individual vs. Professional Hosts",
    x = NULL,
    y = "Price per Night"
  ) +
  theme_minimal(base_size = 13) +
  theme(
    legend.position = "none",
    strip.background = element_rect(fill = "grey95", color = NA),
    strip.text = element_text(face = "bold"),
    panel.grid.minor = element_blank(),
    axis.text.x = element_text(angle = 45, hjust = 1)
  )

print(price_distr)
print(price_dist_plot)
print(borough_stats_plot)

