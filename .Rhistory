) +
theme_light()
# Aggregated Trend: Popularity vs. Price by Neighborhood
neighborhood_summary <- airbnb %>%
group_by(neighbourhood, neighbourhood_group) %>%
summarise(
median_price = median(price, na.rm = TRUE),
avg_reviews = mean(number_of_reviews, na.rm = TRUE),
count = n()
) %>%
filter(count > 50) # Only show neighborhoods with significant data
ggplot(neighborhood_summary, aes(x = median_price, y = avg_reviews)) +
geom_point(aes(size = count, color = neighbourhood_group), alpha = 0.6) +
geom_smooth(method = "lm", color = "black", linetype = "dashed", se = FALSE) +
geom_text_repel(aes(label = neighbourhood), size = 3, max.overlaps = 10) +
scale_x_continuous(labels = label_dollar()) +
labs(
title = "Neighborhood Popularity vs. Median Price",
x = "Median Price",
y = "Average Number of Reviews",
size = "Listings Count",
color = "Borough"
) +
theme_light()
