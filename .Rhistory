# Phase 2: Host Category Comparison
# Defining Host Type: Individual (1 listing) vs. Professional (2+ listings)
host_comparison_data <- airbnb %>%
filter(price > 0 & price < 500) %>%
mutate(host_type = ifelse(calculated_host_listings_count > 1, "Professional", "Individual"))
# Plot: Comparing price distributions by Host Type across Boroughs
ggplot(host_comparison_data, aes(x = host_type, y = price, fill = host_type)) +
geom_boxplot(outlier.alpha = 0.05, outlier.size = 0.5, color = "#34495E") +
facet_wrap(~neighbourhood_group, nrow = 1) +
scale_y_continuous(labels = label_dollar()) +
scale_fill_manual(values = c("#AAB7B8", "#F39C12")) + # Muted grey for individuals, bold orange for pros
labs(
title = "Pricing Comparison: Individual vs. Professional Hosts",
x = NULL,
y = "Price per Night"
) +
theme_minimal(base_size = 13) +
theme(
legend.position = "none",
strip.background = element_rect(fill = "grey95", color = NA),
strip.text = element_text(face = "bold"),
panel.grid.minor = element_blank(),
axis.text.x = element_text(angle = 45, hjust = 1)
)
