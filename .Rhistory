geom_boxplot(width = 0.1, color = "#2C3E50", outlier.shape = NA) + # Hide outliers to focus on the 'body'
scale_y_log10(labels = label_dollar(), breaks = c(10, 50, 100, 250, 500, 1000, 5000)) +
scale_fill_viridis_d(option = "plasma") +
labs(
title = "Statistical Spread of Prices (Log Scale)",
subtitle = "The boxplots reveal that Brooklyn and Manhattan have the highest median costs.",
x = "Borough",
y = "Price (Log 10)"
) +
theme_classic() +
theme(legend.position = "none")
# --- 3. TRENDS: Popularity vs. Price (Topics 8 & 11) ---
# Goal: Show the relationship between price and number of reviews.
trend_analysis_plot <- airbnb %>%
filter(price < 1000) %>%
ggplot(aes(x = price, y = number_of_reviews)) +
geom_point(alpha = 0.05, color = "#34495E") + # Extreme transparency to handle overplotting
geom_smooth(method = "loess", color = "#E74C3C", size = 1.2) +
scale_x_continuous(labels = label_dollar()) +
coord_cartesian(ylim = c(0, 150)) + # Zoom in on the trend
labs(
title = "Is Lower Price Linked to Higher Popularity?",
subtitle = "Review activity peaks sharply for listings under $150 per night.",
x = "Price per Night",
y = "Total Number of Reviews"
) +
theme_minimal()
# --- DISPLAY ALL ---
print(price_dist_plot)
print(borough_stats_plot)
print(trend_analysis_plot)
# Load libraries
library(ggplot2)
library(dplyr)
library(viridis)
library(scales)
# --- 1. DISTRIBUTION: Price Density (Topic 9 & 13) ---
# Cleaned: Subtitle removed, simplified color scale.
price_dist_plot <- airbnb %>%
filter(price > 0 & price < 500) %>%
ggplot(aes(x = price, y = reorder(neighbourhood_group, price, FUN = median), fill = ..x..)) +
geom_density_ridges_gradient(scale = 3, rel_min_height = 0.01) +
scale_fill_viridis_c(option = "mako") +
scale_x_continuous(labels = label_dollar()) +
labs(
title = "Price Distribution by Borough",
x = "Price per Night",
y = NULL
) +
theme_minimal() +
theme(legend.position = "none")
# --- 2. STATS: Flipped Borough Comparison (Topic 9 & 11) ---
# Modification: Switched to a flipped boxplot and capped price at $500.
# Flipped coordinates make the borough names much easier to read.
borough_stats_plot <- airbnb %>%
filter(price > 0 & price < 500) %>%
ggplot(aes(x = reorder(neighbourhood_group, price, FUN = median), y = price, fill = neighbourhood_group)) +
geom_boxplot(outlier.alpha = 0.1, outlier.size = 0.5, color = "#2C3E50") +
coord_flip() + # Makes it much more legible
scale_y_continuous(labels = label_dollar()) +
scale_fill_viridis_d(option = "plasma") +
labs(
title = "Price Variance Across NYC Boroughs",
x = NULL,
y = "Price per Night"
) +
theme_light() +
theme(legend.position = "none")
# --- 3. TRENDS: Heatmap Density Trend (Topic 8 & 11) ---
# Modification: Replaced overplotted points with 'geom_bin2d'.
# This shows where the "mass" of the data is without individual point clutter.
trend_analysis_plot <- airbnb %>%
filter(price > 0 & price < 600 & number_of_reviews < 200) %>%
ggplot(aes(x = price, y = number_of_reviews)) +
geom_bin2d(bins = 40) + # Aggregates points into a legible heatmap
geom_smooth(method = "loess", color = "#E74C3C", size = 1.5, se = FALSE) +
scale_fill_viridis_c(option = "magma", trans = "log") + # Log scale for the fill color
scale_x_continuous(labels = label_dollar()) +
labs(
title = "Relationship Between Price and Reviews",
x = "Price per Night",
y = "Number of Reviews",
fill = "Density"
) +
theme_minimal()
# Display results
print(price_dist_plot)
print(borough_stats_plot)
# Display results
print(price_dist_plot)
print(borough_stats_plot)
print(trend_analysis_plot)
