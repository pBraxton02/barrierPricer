geom_density_ridges(alpha = 0.7, quantile_lines = TRUE, quantiles = 2, color = "white") +
scale_x_log10(labels = label_dollar(), breaks = c(25, 50, 100, 200, 400, 800)) +
scale_fill_viridis_d(option = "viridis") +
labs(
title = "Market Price Segments by Borough",
x = "Price per Night (Log Scale)",
